[
  {
    "text": "人生如逆旅，我亦是行人",
    "from": "苏轼《临江仙·送钱穆父》",
    "category": "poetry"
  },
  {
    "text": "长风破浪会有时，直挂云帆济沧海",
    "from": "李白《行路难》",
    "category": "poetry"
  },
  {
    "text": "天生我材必有用，千金散尽还复来",
    "from": "李白《将进酒》",
    "category": "poetry"
  },
  {
    "text": "此情可待成追忆，只是当时已惘然",
    "from": "李商隐《锦瑟》",
    "category": "poetry"
  },
  {
    "text": "竹杖芒鞋轻胜马，谁怕？一蓑烟雨任平生",
    "from": "苏轼《定风波》",
    "category": "poetry"
  },
  {
    "text": "众里寻他千百度，蓦然回首，那人却在灯火阑珊处",
    "from": "辛弃疾《青玉案·元夕》",
    "category": "poetry"
  },
  {
    "text": "不识庐山真面目，只缘身在此山中",
    "from": "苏轼《题西林壁》",
    "category": "poetry"
  },
  {
    "text": "问渠那得清如许，为有源头活水来",
    "from": "朱熹《观书有感》",
    "category": "poetry"
  },
  {
    "text": "山重水复疑无路，柳暗花明又一村",
    "from": "陆游《游山西村》",
    "category": "poetry"
  },
  {
    "text": "海内存知己，天涯若比邻",
    "from": "王勃《送杜少府之任蜀州》",
    "category": "poetry"
  },
  {
    "text": "莫愁前路无知己，天下谁人不识君",
    "from": "高适《别董大》",
    "category": "poetry"
  },
  {
    "text": "落红不是无情物，化作春泥更护花",
    "from": "龚自珍《己亥杂诗》",
    "category": "poetry"
  },
  {
    "text": "千淘万漉虽辛苦，吹尽狂沙始到金",
    "from": "刘禹锡《浪淘沙》",
    "category": "poetry"
  },
  {
    "text": "沉舟侧畔千帆过，病树前头万木春",
    "from": "刘禹锡《酬乐天扬州初逢席上见赠》",
    "category": "poetry"
  },
  {
    "text": "会当凌绝顶，一览众山小",
    "from": "杜甫《望岳》",
    "category": "poetry"
  },
  {
    "text": "采菊东篱下，悠然见南山",
    "from": "陶渊明《饮酒》",
    "category": "poetry"
  },
  {
    "text": "行到水穷处，坐看云起时",
    "from": "王维《终南别业》",
    "category": "poetry"
  },
  {
    "text": "但愿人长久，千里共婵娟",
    "from": "苏轼《水调歌头》",
    "category": "poetry"
  },
  {
    "text": "纸上得来终觉浅，绝知此事要躬行",
    "from": "陆游《冬夜读书示子聿》",
    "category": "poetry"
  },
  {
    "text": "宝剑锋从磨砺出，梅花香自苦寒来",
    "from": "《警世贤文》",
    "category": "poetry"
  },
  {
    "text": "业精于勤荒于嬉，行成于思毁于随",
    "from": "韩愈《进学解》",
    "category": "poetry"
  },
  {
    "text": "路漫漫其修远兮，吾将上下而求索",
    "from": "屈原《离骚》",
    "category": "poetry"
  },
  {
    "text": "老骥伏枥，志在千里；烈士暮年，壮心不已",
    "from": "曹操《龟虽寿》",
    "category": "poetry"
  },
  {
    "text": "时人不识凌云木，直待凌云始道高",
    "from": "杜荀鹤《小松》",
    "category": "poetry"
  },
  {
    "text": "看似寻常最奇崛，成如容易却艰辛",
    "from": "王安石《题张司业诗》",
    "category": "poetry"
  },
  {
    "text": "大鹏一日同风起，扶摇直上九万里",
    "from": "李白《上李邕》",
    "category": "poetry"
  },
  {
    "text": "最是人间留不住，朱颜辞镜花辞树",
    "from": "王国维《蝶恋花》",
    "category": "poetry"
  },
  {
    "text": "人生若只如初见，何事秋风悲画扇",
    "from": "纳兰性德《木兰花》",
    "category": "poetry"
  },
  {
    "text": "世间安得双全法，不负如来不负卿",
    "from": "仓央嘉措",
    "category": "poetry"
  },
  {
    "text": "回首向来萧瑟处，归去，也无风雨也无晴",
    "from": "苏轼《定风波》",
    "category": "poetry"
  },
  {
    "text": "醉后不知天在水，满船清梦压星河",
    "from": "唐珙《题龙阳县青草湖》",
    "category": "poetry"
  },
  {
    "text": "举杯邀明月，对影成三人",
    "from": "李白《月下独酌》",
    "category": "poetry"
  },
  {
    "text": "我生待明日，万事成蹉跎",
    "from": "钱福《明日歌》",
    "category": "poetry"
  },
  {
    "text": "少年易老学难成，一寸光阴不可轻",
    "from": "朱熹《偶成》",
    "category": "poetry"
  },
  {
    "text": "黄沙百战穿金甲，不破楼兰终不还",
    "from": "王昌龄《从军行》",
    "category": "poetry"
  },
  {
    "text": "洛阳亲友如相问，一片冰心在玉壶",
    "from": "王昌龄《芙蓉楼送辛渐》",
    "category": "poetry"
  },
  {
    "text": "劝君更尽一杯酒，西出阳关无故人",
    "from": "王维《送元二使安西》",
    "category": "poetry"
  },
  {
    "text": "独在异乡为异客，每逢佳节倍思亲",
    "from": "王维《九月九日忆山东兄弟》",
    "category": "poetry"
  },
  {
    "text": "随风潜入夜，润物细无声",
    "from": "杜甫《春夜喜雨》",
    "category": "poetry"
  },
  {
    "text": "无边落木萧萧下，不尽长江滚滚来",
    "from": "杜甫《登高》",
    "category": "poetry"
  },
  {
    "text": "出师未捷身先死，长使英雄泪满襟",
    "from": "杜甫《蜀相》",
    "category": "poetry"
  },
  {
    "text": "安得广厦千万间，大庇天下寒士俱欢颜",
    "from": "杜甫《茅屋为秋风所破歌》",
    "category": "poetry"
  },
  {
    "text": "白日放歌须纵酒，青春作伴好还乡",
    "from": "杜甫《闻官军收河南河北》",
    "category": "poetry"
  },
  {
    "text": "春蚕到死丝方尽，蜡炬成灰泪始干",
    "from": "李商隐《无题》",
    "category": "poetry"
  },
  {
    "text": "相见时难别亦难，东风无力百花残",
    "from": "李商隐《无题》",
    "category": "poetry"
  },
  {
    "text": "曾经沧海难为水，除却巫山不是云",
    "from": "元稹《离思》",
    "category": "poetry"
  },
  {
    "text": "孤帆远影碧空尽，唯见长江天际流",
    "from": "李白《黄鹤楼送孟浩然之广陵》",
    "category": "poetry"
  },
  {
    "text": "桃花潭水深千尺，不及汪伦送我情",
    "from": "李白《赠汪伦》",
    "category": "poetry"
  },
  {
    "text": "飞流直下三千尺，疑是银河落九天",
    "from": "李白《望庐山瀑布》",
    "category": "poetry"
  },
  {
    "text": "两岸猿声啼不住，轻舟已过万重山",
    "from": "李白《早发白帝城》",
    "category": "poetry"
  },
  {
    "text": "抽刀断水水更流，举杯消愁愁更愁",
    "from": "李白《宣州谢朓楼饯别校书叔云》",
    "category": "poetry"
  },
  {
    "text": "人生得意须尽欢，莫使金樽空对月",
    "from": "李白《将进酒》",
    "category": "poetry"
  },
  {
    "text": "古来圣贤皆寂寞，惟有饮者留其名",
    "from": "李白《将进酒》",
    "category": "poetry"
  },
  {
    "text": "君不见黄河之水天上来，奔流到海不复回",
    "from": "李白《将进酒》",
    "category": "poetry"
  },
  {
    "text": "君不见高堂明镜悲白发，朝如青丝暮成雪",
    "from": "李白《将进酒》",
    "category": "poetry"
  },
  {
    "text": "孤舟蓑笠翁，独钓寒江雪",
    "from": "柳宗元《江雪》",
    "category": "poetry"
  },
  {
    "text": "千山鸟飞绝，万径人踪灭",
    "from": "柳宗元《江雪》",
    "category": "poetry"
  },
  {
    "text": "忽如一夜春风来，千树万树梨花开",
    "from": "岑参《白雪歌送武判官归京》",
    "category": "poetry"
  },
  {
    "text": "烟笼寒水月笼沙，夜泊秦淮近酒家",
    "from": "杜牧《泊秦淮》",
    "category": "poetry"
  },
  {
    "text": "停车坐爱枫林晚，霜叶红于二月花",
    "from": "杜牧《山行》",
    "category": "poetry"
  },
  {
    "text": "清明时节雨纷纷，路上行人欲断魂",
    "from": "杜牧《清明》",
    "category": "poetry"
  },
  {
    "text": "借问酒家何处有，牧童遥指杏花村",
    "from": "杜牧《清明》",
    "category": "poetry"
  },
  {
    "text": "大漠孤烟直，长河落日圆",
    "from": "王维《使至塞上》",
    "category": "poetry"
  },
  {
    "text": "明月松间照，清泉石上流",
    "from": "王维《山居秋暝》",
    "category": "poetry"
  },
  {
    "text": "空山新雨后，天气晚来秋",
    "from": "王维《山居秋暝》",
    "category": "poetry"
  },
  {
    "text": "劝君莫惜金缕衣，劝君惜取少年时",
    "from": "《金缕衣》",
    "category": "poetry"
  },
  {
    "text": "花开堪折直须折，莫待无花空折枝",
    "from": "《金缕衣》",
    "category": "poetry"
  },
  {
    "text": "昨夜西风凋碧树，独上高楼，望尽天涯路",
    "from": "晏殊《蝶恋花》",
    "category": "poetry"
  },
  {
    "text": "衣带渐宽终不悔，为伊消得人憔悴",
    "from": "柳永《蝶恋花》",
    "category": "poetry"
  },
  {
    "text": "多情自古伤离别，更那堪冷落清秋节",
    "from": "柳永《雨霖铃》",
    "category": "poetry"
  },
  {
    "text": "无可奈何花落去，似曾相识燕归来",
    "from": "晏殊《浣溪沙》",
    "category": "poetry"
  },
  {
    "text": "枝上柳绵吹又少，天涯何处无芳草",
    "from": "苏轼《蝶恋花·春景》",
    "category": "poetry"
  },
  {
    "text": "人生到处知何似，应似飞鸿踏雪泥",
    "from": "苏轼《和子由渑池怀旧》",
    "category": "poetry"
  },
  {
    "text": "欲把西湖比西子，淡妆浓抹总相宜",
    "from": "苏轼《饮湖上初晴后雨》",
    "category": "poetry"
  },
  {
    "text": "小舟从此逝，江海寄余生",
    "from": "苏轼《临江仙》",
    "category": "poetry"
  },
  {
    "text": "宁可枝头抱香死，何曾吹落北风中",
    "from": "郑思肖《寒菊》",
    "category": "poetry"
  },
  {
    "text": "人生自古谁无死，留取丹心照汗青",
    "from": "文天祥《过零丁洋》",
    "category": "poetry"
  },
  {
    "text": "不畏浮云遮望眼，自缘身在最高层",
    "from": "王安石《登飞来峰》",
    "category": "poetry"
  },
  {
    "text": "春风又绿江南岸，明月何时照我还",
    "from": "王安石《泊船瓜洲》",
    "category": "poetry"
  },
  {
    "text": "等闲识得东风面，万紫千红总是春",
    "from": "朱熹《春日》",
    "category": "poetry"
  },
  {
    "text": "生当作人杰，死亦为鬼雄",
    "from": "李清照《夏日绝句》",
    "category": "poetry"
  },
  {
    "text": "知否知否，应是绿肥红瘦",
    "from": "李清照《如梦令》",
    "category": "poetry"
  },
  {
    "text": "莫道不销魂，帘卷西风，人比黄花瘦",
    "from": "李清照《醉花阴》",
    "category": "poetry"
  },
  {
    "text": "寻寻觅觅，冷冷清清，凄凄惨惨戚戚",
    "from": "李清照《声声慢》",
    "category": "poetry"
  },
  {
    "text": "两情若是久长时，又岂在朝朝暮暮",
    "from": "秦观《鹊桥仙》",
    "category": "poetry"
  },
  {
    "text": "金风玉露一相逢，便胜却人间无数",
    "from": "秦观《鹊桥仙》",
    "category": "poetry"
  },
  {
    "text": "今人不见古时月，今月曾经照古人",
    "from": "李白《把酒问月》",
    "category": "poetry"
  },
  {
    "text": "自古逢秋悲寂寥，我言秋日胜春朝",
    "from": "刘禹锡《秋词》",
    "category": "poetry"
  },
  {
    "text": "旧时王谢堂前燕，飞入寻常百姓家",
    "from": "刘禹锡《乌衣巷》",
    "category": "poetry"
  },
  {
    "text": "东边日出西边雨，道是无晴却有晴",
    "from": "刘禹锡《竹枝词》",
    "category": "poetry"
  },
  {
    "text": "同是天涯沦落人，相逢何必曾相识",
    "from": "白居易《琵琶行》",
    "category": "poetry"
  },
  {
    "text": "野火烧不尽，春风吹又生",
    "from": "白居易《赋得古原草送别》",
    "category": "poetry"
  },
  {
    "text": "日出江花红胜火，春来江水绿如蓝",
    "from": "白居易《忆江南》",
    "category": "poetry"
  },
  {
    "text": "夕阳无限好，只是近黄昏",
    "from": "李商隐《登乐游原》",
    "category": "poetry"
  },
  {
    "text": "青山一道同云雨，明月何曾是两乡",
    "from": "王昌龄《送柴侍御》",
    "category": "poetry"
  },
  {
    "text": "正是江南好风景，落花时节又逢君",
    "from": "杜甫《江南逢李龟年》",
    "category": "poetry"
  },
  {
    "text": "此曲只应天上有，人间能得几回闻",
    "from": "杜甫《赠花卿》",
    "category": "poetry"
  },
  {
    "text": "近水楼台先得月，向阳花木易为春",
    "from": "苏麟《断句》",
    "category": "poetry"
  },
  {
    "text": "月落乌啼霜满天，江枫渔火对愁眠",
    "from": "张继《枫桥夜泊》",
    "category": "poetry"
  },
  {
    "text": "落霞与孤鹜齐飞，秋水共长天一色",
    "from": "王勃《滕王阁序》",
    "category": "poetry"
  },
  {
    "text": "关关雎鸠，在河之洲。窈窕淑女，君子好逑",
    "from": "《诗经·关雎》",
    "category": "poetry"
  },
  {
    "text": "蒹葭苍苍，白露为霜。所谓伊人，在水一方",
    "from": "《诗经·蒹葭》",
    "category": "poetry"
  },
  {
    "text": "死生契阔，与子成说。执子之手，与子偕老",
    "from": "《诗经·击鼓》",
    "category": "poetry"
  },
  {
    "text": "投我以木桃，报之以琼瑶",
    "from": "《诗经·木瓜》",
    "category": "poetry"
  },
  {
    "text": "他山之石，可以攻玉",
    "from": "《诗经·鹤鸣》",
    "category": "poetry"
  },
  {
    "text": "如切如磋，如琢如磨",
    "from": "《诗经·淇奥》",
    "category": "poetry"
  },
  {
    "text": "靡不有初，鲜克有终",
    "from": "《诗经·荡》",
    "category": "poetry"
  },
  {
    "text": "知我者谓我心忧，不知我者谓我何求",
    "from": "《诗经·黍离》",
    "category": "poetry"
  },
  {
    "text": "高山仰止，景行行止",
    "from": "《诗经·车舝》",
    "category": "poetry"
  },
  {
    "text": "昔我往矣，杨柳依依。今我来思，雨雪霏霏",
    "from": "《诗经·采薇》",
    "category": "poetry"
  },
  {
    "text": "桃之夭夭，灼灼其华",
    "from": "《诗经·桃夭》",
    "category": "poetry"
  },
  {
    "text": "北国风光，千里冰封，万里雪飘",
    "from": "毛泽东《沁园春·雪》",
    "category": "poetry"
  },
  {
    "text": "俱往矣，数风流人物，还看今朝",
    "from": "毛泽东《沁园春·雪》",
    "category": "poetry"
  },
  {
    "text": "雄关漫道真如铁，而今迈步从头越",
    "from": "毛泽东《忆秦娥·娄山关》",
    "category": "poetry"
  },
  {
    "text": "一万年太久，只争朝夕",
    "from": "毛泽东《满江红·和郭沫若同志》",
    "category": "poetry"
  },
  {
    "text": "一蓑一笠一扁舟，一丈丝纶一寸钩",
    "from": "王士禛《题秋江独钓图》",
    "category": "poetry"
  },
  {
    "text": "天长地久有时尽，此恨绵绵无绝期",
    "from": "白居易《长恨歌》",
    "category": "poetry"
  },
  {
    "text": "在天愿作比翼鸟，在地愿为连理枝",
    "from": "白居易《长恨歌》",
    "category": "poetry"
  },
  {
    "text": "商女不知亡国恨，隔江犹唱后庭花",
    "from": "杜牧《泊秦淮》",
    "category": "poetry"
  },
  {
    "text": "他年我若为青帝，报与桃花一处开",
    "from": "黄巢《题菊花》",
    "category": "poetry"
  },
  {
    "text": "冲天香阵透长安，满城尽带黄金甲",
    "from": "黄巢《不第后赋菊》",
    "category": "poetry"
  },
  {
    "text": "晴川历历汉阳树，芳草萋萋鹦鹉洲",
    "from": "崔颢《黄鹤楼》",
    "category": "poetry"
  },
  {
    "text": "山回路转不见君，雪上空留马行处",
    "from": "岑参《白雪歌送武判官归京》",
    "category": "poetry"
  },
  {
    "text": "今宵酒醒何处，杨柳岸晓风残月",
    "from": "柳永《雨霖铃》",
    "category": "poetry"
  },
  {
    "text": "认识你自己",
    "from": "苏格拉底",
    "category": "philosophy"
  },
  {
    "text": "我思故我在",
    "from": "笛卡尔",
    "category": "philosophy"
  },
  {
    "text": "存在先于本质",
    "from": "萨特",
    "category": "philosophy"
  },
  {
    "text": "人是会思想的芦苇",
    "from": "帕斯卡",
    "category": "philosophy"
  },
  {
    "text": "未经审视的人生不值得过",
    "from": "苏格拉底",
    "category": "philosophy"
  },
  {
    "text": "幸福就是身体无痛苦，灵魂无烦恼",
    "from": "伊壁鸠鲁",
    "category": "philosophy"
  },
  {
    "text": "宁做痛苦的苏格拉底，不做满足的猪",
    "from": "约翰·密尔",
    "category": "philosophy"
  },
  {
    "text": "所谓自由，不是随心所欲，而是自我主宰",
    "from": "康德",
    "category": "philosophy"
  },
  {
    "text": "世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空",
    "from": "康德",
    "category": "philosophy"
  },
  {
    "text": "存在即合理",
    "from": "黑格尔",
    "category": "philosophy"
  },
  {
    "text": "人是一根绳索，连接在动物和超人之间",
    "from": "尼采",
    "category": "philosophy"
  },
  {
    "text": "凡不能毁灭我的，必使我更强大",
    "from": "尼采",
    "category": "philosophy"
  },
  {
    "text": "其实人跟树是一样的，越是向往高处的阳光，根就越要伸向黑暗的地底",
    "from": "尼采",
    "category": "philosophy"
  },
  {
    "text": "每个不曾起舞的日子，都是对生命的辜负",
    "from": "尼采",
    "category": "philosophy"
  },
  {
    "text": "人生而自由，却无往不在枷锁之中",
    "from": "卢梭",
    "category": "philosophy"
  },
  {
    "text": "他人即地狱",
    "from": "萨特",
    "category": "philosophy"
  },
  {
    "text": "人类从历史中学到的唯一教训，就是人类无法从历史中学到任何教训",
    "from": "黑格尔",
    "category": "philosophy"
  },
  {
    "text": "伟大的哲学始于怀疑，终于信仰",
    "from": "培根",
    "category": "philosophy"
  },
  {
    "text": "此亦一是非，彼亦一是非",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "子非鱼，安知鱼之乐",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "吾生也有涯，而知也无涯",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "相濡以沫，不如相忘于江湖",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "天地与我并生，而万物与我为一",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "道可道，非常道；名可名，非常名",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "上善若水，水善利万物而不争",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "知人者智，自知者明",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "胜人者有力，自胜者强",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "大方无隅，大器晚成，大音希声，大象无形",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "千里之行，始于足下",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "知止而后有定，定而后能静，静而后能安，安而后能虑，虑而后能得",
    "from": "《大学》",
    "category": "philosophy"
  },
  {
    "text": "己所不欲，勿施于人",
    "from": "孔子",
    "category": "philosophy"
  },
  {
    "text": "学而不思则罔，思而不学则殆",
    "from": "孔子",
    "category": "philosophy"
  },
  {
    "text": "知之者不如好之者，好之者不如乐之者",
    "from": "孔子",
    "category": "philosophy"
  },
  {
    "text": "三人行，必有我师焉",
    "from": "孔子",
    "category": "philosophy"
  },
  {
    "text": "岁寒，然后知松柏之后凋也",
    "from": "孔子",
    "category": "philosophy"
  },
  {
    "text": "天行健，君子以自强不息",
    "from": "《周易》",
    "category": "philosophy"
  },
  {
    "text": "地势坤，君子以厚德载物",
    "from": "《周易》",
    "category": "philosophy"
  },
  {
    "text": "穷则变，变则通，通则久",
    "from": "《周易》",
    "category": "philosophy"
  },
  {
    "text": "博学之，审问之，慎思之，明辨之，笃行之",
    "from": "《中庸》",
    "category": "philosophy"
  },
  {
    "text": "祸兮福之所倚，福兮祸之所伏",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "合抱之木，生于毫末；九层之台，起于累土",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "信言不美，美言不信",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "知者不言，言者不知",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "人法地，地法天，天法道，道法自然",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "有无相生，难易相成，长短相形，高下相倾",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "为学日益，为道日损",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "五色令人目盲，五音令人耳聋",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "天下之至柔，驰骋天下之至坚",
    "from": "老子《道德经》",
    "category": "philosophy"
  },
  {
    "text": "致知在格物",
    "from": "《礼记·大学》",
    "category": "philosophy"
  },
  {
    "text": "行有不得，反求诸己",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "穷则独善其身，达则兼济天下",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "富贵不能淫，贫贱不能移，威武不能屈",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "天将降大任于斯人也，必先苦其心志，劳其筋骨",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "得道多助，失道寡助",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "生于忧患，死于安乐",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "民为贵，社稷次之，君为轻",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "尽信书，则不如无书",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "非淡泊无以明志，非宁静无以致远",
    "from": "诸葛亮《诫子书》",
    "category": "philosophy"
  },
  {
    "text": "静以修身，俭以养德",
    "from": "诸葛亮《诫子书》",
    "category": "philosophy"
  },
  {
    "text": "勿以恶小而为之，勿以善小而不为",
    "from": "刘备",
    "category": "philosophy"
  },
  {
    "text": "读书破万卷，下笔如有神",
    "from": "杜甫",
    "category": "philosophy"
  },
  {
    "text": "世事洞明皆学问，人情练达即文章",
    "from": "曹雪芹《红楼梦》",
    "category": "philosophy"
  },
  {
    "text": "假作真时真亦假，无为有处有还无",
    "from": "曹雪芹《红楼梦》",
    "category": "philosophy"
  },
  {
    "text": "身后有余忘缩手，眼前无路想回头",
    "from": "曹雪芹《红楼梦》",
    "category": "philosophy"
  },
  {
    "text": "古人不见今时月，今月曾经照古人",
    "from": "《增广贤文》",
    "category": "philosophy"
  },
  {
    "text": "有意栽花花不发，无心插柳柳成荫",
    "from": "《增广贤文》",
    "category": "philosophy"
  },
  {
    "text": "良药苦口利于病，忠言逆耳利于行",
    "from": "《增广贤文》",
    "category": "philosophy"
  },
  {
    "text": "一年之计在于春，一日之计在于晨",
    "from": "《增广贤文》",
    "category": "philosophy"
  },
  {
    "text": "学如逆水行舟，不进则退",
    "from": "《增广贤文》",
    "category": "philosophy"
  },
  {
    "text": "人无远虑，必有近忧",
    "from": "《论语·卫灵公》",
    "category": "philosophy"
  },
  {
    "text": "小不忍则乱大谋",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "欲速则不达",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "朝闻道，夕死可矣",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "温故而知新，可以为师矣",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "敏而好学，不耻下问",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "有教无类",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "德不孤，必有邻",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "不在其位，不谋其政",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "工欲善其事，必先利其器",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "饱食终日，无所用心，难矣哉",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "往者不可谏，来者犹可追",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "君子和而不同，小人同而不和",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "志士仁人，无求生以害仁，有杀身以成仁",
    "from": "《论语》",
    "category": "philosophy"
  },
  {
    "text": "唯一真正的智慧是知道自己一无所知",
    "from": "苏格拉底",
    "category": "philosophy"
  },
  {
    "text": "爱智慧的人，才是真正自由的人",
    "from": "柏拉图",
    "category": "philosophy"
  },
  {
    "text": "理想存在于观念之中，现实只是它的影子",
    "from": "柏拉图",
    "category": "philosophy"
  },
  {
    "text": "良好的开端，等于成功的一半",
    "from": "柏拉图",
    "category": "philosophy"
  },
  {
    "text": "人生最遗憾的，莫过于轻易放弃了不该放弃的，固执地坚持了不该坚持的",
    "from": "柏拉图",
    "category": "philosophy"
  },
  {
    "text": "真理是时间的产物，而不是权威的产物",
    "from": "培根",
    "category": "philosophy"
  },
  {
    "text": "知识就是力量",
    "from": "培根",
    "category": "philosophy"
  },
  {
    "text": "怀疑是走向真理的第一步",
    "from": "笛卡尔",
    "category": "philosophy"
  },
  {
    "text": "我不同意你的观点，但我誓死捍卫你说话的权利",
    "from": "伏尔泰",
    "category": "philosophy"
  },
  {
    "text": "没有所谓命运这个东西，一切无非是考验、惩罚或补偿",
    "from": "伏尔泰",
    "category": "philosophy"
  },
  {
    "text": "人的本能是追逐从他身边飞走的东西，却逃避追逐他的东西",
    "from": "伏尔泰",
    "category": "philosophy"
  },
  {
    "text": "自由不是做你想做的事，而是不做你不想做的事",
    "from": "卢梭",
    "category": "philosophy"
  },
  {
    "text": "忍耐是苦涩的，但它的果实却是甘甜的",
    "from": "卢梭",
    "category": "philosophy"
  },
  {
    "text": "人是生而自由的，但却无往不在枷锁中",
    "from": "卢梭",
    "category": "philosophy"
  },
  {
    "text": "良心是声音，而理智是回声",
    "from": "爱默生",
    "category": "philosophy"
  },
  {
    "text": "你的善良必须有点锋芒",
    "from": "爱默生",
    "category": "philosophy"
  },
  {
    "text": "浅薄的人相信运气，坚强的人相信因果",
    "from": "爱默生",
    "category": "philosophy"
  },
  {
    "text": "一个人的品格，可以从他对无聊时间的处理方式看出",
    "from": "叔本华",
    "category": "philosophy"
  },
  {
    "text": "生命是一团欲望，欲望不满足便痛苦，满足便无聊",
    "from": "叔本华",
    "category": "philosophy"
  },
  {
    "text": "没有人生活在过去，也没有人生活在未来，现在是生命确实占有的唯一形态",
    "from": "叔本华",
    "category": "philosophy"
  },
  {
    "text": "要么孤独，要么庸俗",
    "from": "叔本华",
    "category": "philosophy"
  },
  {
    "text": "世界上只有一种真正的英雄主义，那就是在认清生活真相之后依然热爱生活",
    "from": "罗曼·罗兰",
    "category": "modern"
  },
  {
    "text": "活着本身就是意义",
    "from": "余华《活着》",
    "category": "modern"
  },
  {
    "text": "满地都是六便士，他却抬头看见了月亮",
    "from": "毛姆《月亮与六便士》",
    "category": "modern"
  },
  {
    "text": "我们终此一生，就是要摆脱他人的期待，找到真正的自己",
    "from": "伍绮诗《无声告白》",
    "category": "modern"
  },
  {
    "text": "如果把童年再放映一遍，我们一定会先大笑，然后放声大哭，最后挂着泪，微笑着睡去",
    "from": "宫崎骏",
    "category": "modern"
  },
  {
    "text": "我来不及认真地年轻，待明白过来时，只能选择认真地老去",
    "from": "三毛",
    "category": "modern"
  },
  {
    "text": "读书多了，容颜自然改变",
    "from": "三毛",
    "category": "modern"
  },
  {
    "text": "心之何如，有似万丈迷津，遥亘千里，其中并无舟子可以渡人，除了自渡，他人爱莫能助",
    "from": "三毛",
    "category": "modern"
  },
  {
    "text": "世界以痛吻我，要我报之以歌",
    "from": "泰戈尔",
    "category": "modern"
  },
  {
    "text": "如果你因失去了太阳而流泪，那么你也将失去群星了",
    "from": "泰戈尔",
    "category": "modern"
  },
  {
    "text": "生如夏花之绚烂，死如秋叶之静美",
    "from": "泰戈尔",
    "category": "modern"
  },
  {
    "text": "黑夜给了我黑色的眼睛，我却用它寻找光明",
    "from": "顾城",
    "category": "modern"
  },
  {
    "text": "面朝大海，春暖花开",
    "from": "海子",
    "category": "modern"
  },
  {
    "text": "要有最朴素的生活和最遥远的梦想，即使明天天寒地冻，路远马亡",
    "from": "海子",
    "category": "modern"
  },
  {
    "text": "因为懂得，所以慈悲",
    "from": "张爱玲",
    "category": "modern"
  },
  {
    "text": "生命是一袭华美的袍，爬满了蚤子",
    "from": "张爱玲",
    "category": "modern"
  },
  {
    "text": "围在城里的人想逃出来，城外的人想冲进去",
    "from": "钱钟书《围城》",
    "category": "modern"
  },
  {
    "text": "天下就没有偶然，那不过是化了妆的必然",
    "from": "钱钟书",
    "category": "modern"
  },
  {
    "text": "人生没有白走的路，每一步都算数",
    "from": "李宗盛",
    "category": "modern"
  },
  {
    "text": "慢慢来，比较快",
    "from": "蒋勋",
    "category": "modern"
  },
  {
    "text": "树在，山在，大地在，岁月在，我在，你还要怎样更好的世界",
    "from": "张晓风",
    "category": "modern"
  },
  {
    "text": "做你自己，因为别人都有人做了",
    "from": "王尔德",
    "category": "modern"
  },
  {
    "text": "我们都生活在阴沟里，但总有人在仰望星空",
    "from": "王尔德",
    "category": "modern"
  },
  {
    "text": "一个人只拥有此生此世是不够的，他还应该拥有诗意的世界",
    "from": "王小波",
    "category": "modern"
  },
  {
    "text": "人的一切痛苦，本质上都是对自己无能的愤怒",
    "from": "王小波",
    "category": "modern"
  },
  {
    "text": "一辈子很长，要跟有趣的人在一起",
    "from": "王小波",
    "category": "modern"
  },
  {
    "text": "万物皆有裂痕，那是光照进来的地方",
    "from": "莱昂纳德·科恩",
    "category": "modern"
  },
  {
    "text": "生活不是等待暴风雨过去，而是学会在雨中翩翩起舞",
    "from": "薇薇安·格林",
    "category": "modern"
  },
  {
    "text": "不乱于心，不困于情，不畏将来，不念过往，如此安好",
    "from": "丰子恺",
    "category": "modern"
  },
  {
    "text": "从明天起，做一个幸福的人，喂马、劈柴，周游世界",
    "from": "海子",
    "category": "modern"
  },
  {
    "text": "愿你出走半生，归来仍是少年",
    "from": "网络",
    "category": "modern"
  },
  {
    "text": "种一棵树最好的时间是十年前，其次是现在",
    "from": "丹比萨·莫约",
    "category": "modern"
  },
  {
    "text": "有些路看起来很近，走下去却很远，缺少耐心永远走不到头",
    "from": "沈从文",
    "category": "modern"
  },
  {
    "text": "你是一树一树的花开，是燕在梁间呢喃，你是爱，是暖，是希望，你是人间的四月天",
    "from": "林徽因",
    "category": "modern"
  },
  {
    "text": "任何瞬间的心动都不容易，不要怠慢了它",
    "from": "毛姆",
    "category": "modern"
  },
  {
    "text": "人的心中，自有两种矛盾的感情。见人不幸，无人不会同情。然而，见人幸福，也无人不会感到嫉妒",
    "from": "芥川龙之介",
    "category": "modern"
  },
  {
    "text": "你的时间有限，不要浪费于重复别人的生活",
    "from": "乔布斯",
    "category": "modern"
  },
  {
    "text": "活着，就是一场修行",
    "from": "网络",
    "category": "modern"
  },
  {
    "text": "人生如茶，空杯以对，才有喝不完的好茶",
    "from": "网络",
    "category": "modern"
  },
  {
    "text": "世界那么大，我想去看看",
    "from": "顾少强",
    "category": "modern"
  },
  {
    "text": "欲穷千里目，更上一层楼",
    "from": "王之涣《登鹳雀楼》",
    "category": "poetry"
  },
  {
    "text": "白日依山尽，黄河入海流",
    "from": "王之涣《登鹳雀楼》",
    "category": "poetry"
  },
  {
    "text": "谁言寸草心，报得三春晖",
    "from": "孟郊《游子吟》",
    "category": "poetry"
  },
  {
    "text": "慈母手中线，游子身上衣",
    "from": "孟郊《游子吟》",
    "category": "poetry"
  },
  {
    "text": "春眠不觉晓，处处闻啼鸟",
    "from": "孟浩然《春晓》",
    "category": "poetry"
  },
  {
    "text": "夜来风雨声，花落知多少",
    "from": "孟浩然《春晓》",
    "category": "poetry"
  },
  {
    "text": "故人具鸡黍，邀我至田家",
    "from": "孟浩然《过故人庄》",
    "category": "poetry"
  },
  {
    "text": "开轩面场圃，把酒话桑麻",
    "from": "孟浩然《过故人庄》",
    "category": "poetry"
  },
  {
    "text": "待到重阳日，还来就菊花",
    "from": "孟浩然《过故人庄》",
    "category": "poetry"
  },
  {
    "text": "野旷天低树，江清月近人",
    "from": "孟浩然《宿建德江》",
    "category": "poetry"
  },
  {
    "text": "红豆生南国，春来发几枝",
    "from": "王维《相思》",
    "category": "poetry"
  },
  {
    "text": "愿君多采撷，此物最相思",
    "from": "王维《相思》",
    "category": "poetry"
  },
  {
    "text": "锄禾日当午，汗滴禾下土",
    "from": "李绅《悯农》",
    "category": "poetry"
  },
  {
    "text": "谁知盘中餐，粒粒皆辛苦",
    "from": "李绅《悯农》",
    "category": "poetry"
  },
  {
    "text": "离离原上草，一岁一枯荣",
    "from": "白居易《赋得古原草送别》",
    "category": "poetry"
  },
  {
    "text": "遥知不是雪，为有暗香来",
    "from": "王安石《梅花》",
    "category": "poetry"
  },
  {
    "text": "墙角数枝梅，凌寒独自开",
    "from": "王安石《梅花》",
    "category": "poetry"
  },
  {
    "text": "接天莲叶无穷碧，映日荷花别样红",
    "from": "杨万里《晓出净慈寺送林子方》",
    "category": "poetry"
  },
  {
    "text": "毕竟西湖六月中，风光不与四时同",
    "from": "杨万里《晓出净慈寺送林子方》",
    "category": "poetry"
  },
  {
    "text": "小荷才露尖尖角，早有蜻蜓立上头",
    "from": "杨万里《小池》",
    "category": "poetry"
  },
  {
    "text": "泉眼无声惜细流，树阴照水爱晴柔",
    "from": "杨万里《小池》",
    "category": "poetry"
  },
  {
    "text": "竹外桃花三两枝，春江水暖鸭先知",
    "from": "苏轼《惠崇春江晚景》",
    "category": "poetry"
  },
  {
    "text": "萧萧梧叶送寒声，江上秋风动客情",
    "from": "叶绍翁《夜书所见》",
    "category": "poetry"
  },
  {
    "text": "应怜屐齿印苍苔，小扣柴扉久不开",
    "from": "叶绍翁《游园不值》",
    "category": "poetry"
  },
  {
    "text": "春色满园关不住，一枝红杏出墙来",
    "from": "叶绍翁《游园不值》",
    "category": "poetry"
  },
  {
    "text": "姑苏城外寒山寺，夜半钟声到客船",
    "from": "张继《枫桥夜泊》",
    "category": "poetry"
  },
  {
    "text": "千门万户曈曈日，总把新桃换旧符",
    "from": "王安石《元日》",
    "category": "poetry"
  },
  {
    "text": "爆竹声中一岁除，春风送暖入屠苏",
    "from": "王安石《元日》",
    "category": "poetry"
  },
  {
    "text": "好雨知时节，当春乃发生",
    "from": "杜甫《春夜喜雨》",
    "category": "poetry"
  },
  {
    "text": "蝉噪林逾静，鸟鸣山更幽",
    "from": "王籍《入若耶溪》",
    "category": "poetry"
  },
  {
    "text": "迟日江山丽，春风花草香",
    "from": "杜甫《绝句》",
    "category": "poetry"
  },
  {
    "text": "窗含西岭千秋雪，门泊东吴万里船",
    "from": "杜甫《绝句》",
    "category": "poetry"
  },
  {
    "text": "两个黄鹂鸣翠柳，一行白鹭上青天",
    "from": "杜甫《绝句》",
    "category": "poetry"
  },
  {
    "text": "碧玉妆成一树高，万条垂下绿丝绦",
    "from": "贺知章《咏柳》",
    "category": "poetry"
  },
  {
    "text": "不知细叶谁裁出，二月春风似剪刀",
    "from": "贺知章《咏柳》",
    "category": "poetry"
  },
  {
    "text": "少小离家老大回，乡音无改鬓毛衰",
    "from": "贺知章《回乡偶书》",
    "category": "poetry"
  },
  {
    "text": "儿童相见不相识，笑问客从何处来",
    "from": "贺知章《回乡偶书》",
    "category": "poetry"
  },
  {
    "text": "葡萄美酒夜光杯，欲饮琵琶马上催",
    "from": "王翰《凉州词》",
    "category": "poetry"
  },
  {
    "text": "醉卧沙场君莫笑，古来征战几人回",
    "from": "王翰《凉州词》",
    "category": "poetry"
  },
  {
    "text": "秦时明月汉时关，万里长征人未还",
    "from": "王昌龄《出塞》",
    "category": "poetry"
  },
  {
    "text": "但使龙城飞将在，不教胡马度阴山",
    "from": "王昌龄《出塞》",
    "category": "poetry"
  },
  {
    "text": "无为其所不为，无欲其所不欲",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "大人者，不失其赤子之心者也",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "人之患在好为人师",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "仰不愧于天，俯不怍于人",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "劳心者治人，劳力者治于人",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "爱人者人恒爱之，敬人者人恒敬之",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "虽有天下易生之物，一日暴之，十日寒之，未有能生者也",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "心不在焉，视而不见，听而不闻，食而不知其味",
    "from": "《大学》",
    "category": "philosophy"
  },
  {
    "text": "苟日新，日日新，又日新",
    "from": "《大学》",
    "category": "philosophy"
  },
  {
    "text": "诚者，天之道也；思诚者，人之道也",
    "from": "《孟子》",
    "category": "philosophy"
  },
  {
    "text": "真悲无声而哀，真怒未发而威，真亲未笑而和",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "大知闲闲，小知间间；大言炎炎，小言詹詹",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "独与天地精神往来，而不敖倪于万物",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "至人无己，神人无功，圣人无名",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "人皆知有用之用，而莫知无用之用也",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "日出而作，日入而息，逍遥于天地之间",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "欲是其所非而非其所是，则莫若以明",
    "from": "庄子",
    "category": "philosophy"
  },
  {
    "text": "以出世的精神，做入世的事业",
    "from": "朱光潜",
    "category": "philosophy"
  },
  {
    "text": "生活就是你的艺术，你把自己谱成乐曲，你的光阴就是十四行诗",
    "from": "王尔德",
    "category": "philosophy"
  },
  {
    "text": "听一个人说话，不要听他怎么说，而要看他怎么做",
    "from": "爱默生",
    "category": "philosophy"
  },
  {
    "text": "勇气不是没有恐惧，而是战胜恐惧",
    "from": "曼德拉",
    "category": "philosophy"
  },
  {
    "text": "教育不是装满一桶水，而是点燃一把火",
    "from": "叶芝",
    "category": "philosophy"
  },
  {
    "text": "你无法在制造问题的同一思维层面上解决该问题",
    "from": "爱因斯坦",
    "category": "philosophy"
  },
  {
    "text": "想象力比知识更重要",
    "from": "爱因斯坦",
    "category": "philosophy"
  },
  {
    "text": "生活就像骑自行车，想保持平衡就要不断前进",
    "from": "爱因斯坦",
    "category": "philosophy"
  },
  {
    "text": "不要努力成为一个成功者，要努力成为一个有价值的人",
    "from": "爱因斯坦",
    "category": "philosophy"
  },
  {
    "text": "在真理和认识方面，任何以权威自居的人，必将在上帝的嬉笑中垮台",
    "from": "爱因斯坦",
    "category": "philosophy"
  },
  {
    "text": "不要温顺地走进那个良夜",
    "from": "狄兰·托马斯",
    "category": "philosophy"
  },
  {
    "text": "只有两样东西是无限的：宇宙和人类的愚蠢",
    "from": "爱因斯坦",
    "category": "philosophy"
  },
  {
    "text": "幸福不在于拥有金钱，而在于获得成就时的喜悦以及创造时的激情",
    "from": "罗斯福",
    "category": "philosophy"
  }
]